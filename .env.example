# Copy to .env (or export in your shell) to override defaults.
# All values shown are the defaults.

# Bind address. Keep 127.0.0.1 unless you know what you are doing.
HOST=127.0.0.1
PORT=4321

# How often collectors poll local files, in milliseconds (min 1000).
POLL_MS=2000

# Where Claude Code keeps per-project JSONL transcripts.
CLAUDE_PROJECTS_DIR=~/.claude/projects

# Where Codex keeps rollout session logs.
CODEX_SESSIONS_DIR=~/.codex/sessions

# Directory for dashboard state files (statusline reporter output, manual overrides).
AGENT_DASHBOARD_DIR=~/.agent-dashboard

# Seconds of transcript inactivity before a "running" agent is considered idle.
RUNNING_THRESHOLD_S=20

# Seconds after which idle sessions disappear from the dashboard.
# Attention sessions stay visible.
SESSION_RETENTION_S=900
