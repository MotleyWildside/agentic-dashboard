{
  "name": "mimiron",
  "version": "0.1.0",
  "description": "Local-first dashboard for monitoring Claude Code and OpenAI Codex agent sessions",
  "type": "module",
  "private": true,
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=22.18"
  },
  "scripts": {
    "dev": "FREE_PORT=1 PORT=8765 node --watch server/index.ts & SERVER=$!; trap 'kill $SERVER 2>/dev/null' EXIT INT TERM; vite",
    "dev:web": "vite",
    "server": "FREE_PORT=1 node --watch server/index.ts",
    "start": "node server/index.ts",
    "scan": "node scripts/scan.ts",
    "test": "node --test \"test/*.test.ts\"",
    "build": "vite build",
    "electron": "npm run build:server && node electron/launch.cjs",
    "app": "npm run build:server && node electron/launch.cjs",
    "dist:mac": "npm run build && npm run build:server && electron-builder --mac",
    "dist:win": "npm run build && npm run build:server && electron-builder --win",
    "dist": "npm run build && npm run build:server && electron-builder -mw",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.server.json --noEmit",
    "build:server": "tsc -p tsconfig.server.json",
    "lint": "npm run lint:docs && npm run lint:arch",
    "lint:docs": "node scripts/lint-docs.ts",
    "lint:arch": "node scripts/lint-arch.ts"
  },
  "build": {
    "appId": "com.wildside.mimiron",
    "productName": "Mimiron",
    "icon": "build/icon",
    "asar": true,
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "electron/**/*",
      "dist-server/server/**/*",
      "dist-server/shared/**/*",
      "server/plugin-assets/**/*",
      "public/**/*",
      "themes/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^6.0.3"
  },
  "allowScripts": {
    "electron@33.4.11": true
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/inter": "^5.2.8",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-grid-layout": "^2.2.3",
    "vite": "^8.1.3"
  }
}
